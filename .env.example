# ── Smart-Claims Agent — Variables d'entorn ──────────────────────────────
# Copia aquest fitxer com a .env i omple els valors reals.
# IMPORTANT: mai commités .env al repositori.

# ── LLM (Anthropic) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Base de dades MariaDB ─────────────────────────────────────────────────
DB_ROOT_PASSWORD=root_s3cret_dev
DB_NAME=smart_claims
DB_USER=claims_user
DB_PASSWORD=claims_s3cret_dev
DB_HOST=mariadb
DB_PORT=3306

# ── ChromaDB ──────────────────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=pepin_policies

# ── Backend ───────────────────────────────────────────────────────────────
BACKEND_URL=http://backend:8000

# ── HITL: llindar d'import per a revisió humana ───────────────────────────
HITL_AMOUNT_THRESHOLD=5000.0

# ── Entorn ────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
